	"item": [
		{
			"name": "Check License Status",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n    \"api_key\": \"{{apiKey}}\",\n    \"api_secret\": \"{{apiSecret}}\"\n}",
					"options": {
						"raw": {
							"language": "json"
						}
					}
				},
				"url": {
					"raw": "{{baseUrl}}/license/status",
					"host": [
						"{{baseUrl}}"
					],
					"path": [
						"license",
						"status"
					]
				},
				"description": "Checks the current status of a license/application."
			},
			"response": []
		},
